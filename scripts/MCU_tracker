#!/usr/bin/env python3
"""Track watched MCU Doomsday watchlist entries."""

from __future__ import annotations

import argparse
import json
import re
import sys
from dataclasses import dataclass
from datetime import date
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
WATCHLIST_JSON_PATH = REPO_ROOT / "reader" / "data" / "watchlist.en.json"
PROGRESS_PATH = REPO_ROOT / "data" / "mcu-watch-progress.json"


@dataclass(frozen=True)
class Title:
    key: str
    title: str
    kind: str
    runtime: str
    bonus: bool
    chronological_order: int


def parse_watchlist() -> list[Title]:
    """Load watchlist from JSON file."""
    if not WATCHLIST_JSON_PATH.exists():
        raise SystemExit(f"Watchlist not found: {WATCHLIST_JSON_PATH}")

    try:
        data = json.loads(WATCHLIST_JSON_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Watchlist JSON is invalid: {WATCHLIST_JSON_PATH}\n{exc}") from exc

    items = data.get("items", [])
    if not isinstance(items, list):
        raise SystemExit(f"Watchlist JSON has invalid items: {WATCHLIST_JSON_PATH}")

    titles: list[Title] = []
    for item in items:
        titles.append(
            Title(
                key=str(item.get("key", "")),
                title=str(item.get("title", "")),
                kind=str(item.get("kind", "Unknown")),
                runtime=str(item.get("runtime", "unknown runtime")),
                bonus=bool(item.get("bonus", False)),
                chronological_order=int(item.get("chronologicalOrder", item.get("key", "0"))),
            )
        )

    return titles


def load_progress() -> dict[str, str]:
    if not PROGRESS_PATH.exists():
        return {}

    try:
        data = json.loads(PROGRESS_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Progress file is invalid JSON: {PROGRESS_PATH}\n{exc}") from exc

    watched = data.get("watched", {})
    if not isinstance(watched, dict):
        raise SystemExit(f"Progress file has an invalid watched map: {PROGRESS_PATH}")

    return {str(key): str(value) for key, value in watched.items()}


def save_progress(watched: dict[str, str]) -> None:
    PROGRESS_PATH.parent.mkdir(parents=True, exist_ok=True)
    payload = {
        "watchlist": str(WATCHLIST_JSON_PATH.relative_to(REPO_ROOT)),
        "updated": date.today().isoformat(),
        "watched": dict(sorted(watched.items(), key=sort_key)),
    }
    PROGRESS_PATH.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def sort_key(item: tuple[str, str]) -> tuple[int, int | str]:
    key = item[0]
    if key.startswith("B"):
        return (1, int(key[1:]))
    return (0, int(key))


def find_title(titles: list[Title], query: str) -> Title:
    normalized = query.casefold().strip()

    for title in titles:
        if title.key.casefold() == normalized:
            return title

    matches = [title for title in titles if normalized in title.title.casefold()]
    if len(matches) == 1:
        return matches[0]

    if not matches:
        raise SystemExit(f"No watchlist entry matches: {query}")

    options = "\n".join(f"  {match.key}. {match.title}" for match in matches)
    raise SystemExit(f"Multiple entries match '{query}':\n{options}")


def parse_entries(entry: str) -> list[str]:
    entries = [part.strip() for part in entry.split(",")]
    return [part for part in entries if part]


def print_list(
    titles: list[Title],
    watched: dict[str, str],
    include_bonus: bool,
    order: str = "release"
) -> None:
    visible = [title for title in titles if include_bonus or not title.bonus]
    
    # Sort by chronological order if requested
    if order == "chronological":
        visible = sorted(visible, key=lambda t: t.chronological_order)
    
    # Calculate width for position display
    if order == "chronological":
        width = max(len(str(title.chronological_order)) for title in visible)
    else:
        width = max(len(title.key) for title in visible)

    for title in visible:
        marker = "x" if title.key in watched else " "
        suffix = f" watched {watched[title.key]}" if title.key in watched else ""
        
        # Display position based on order
        position = str(title.chronological_order) if order == "chronological" else title.key
        
        print(
            f"[{marker}] {position.rjust(width)}. {title.title} "
            f"({title.kind}, {title.runtime}){suffix}"
        )


def print_status(titles: list[Title], watched: dict[str, str]) -> None:
    required = [title for title in titles if not title.bonus]
    bonus = [title for title in titles if title.bonus]
    required_watched = sum(1 for title in required if title.key in watched)
    bonus_watched = sum(1 for title in bonus if title.key in watched)

    print(f"Main watchlist: {required_watched}/{len(required)} watched")
    print(f"Bonus X-Men:    {bonus_watched}/{len(bonus)} watched")

    next_titles = [title for title in required if title.key not in watched][:3]
    if next_titles:
        print("\nNext up:")
        for title in next_titles:
            print(f"  {title.key}. {title.title}")
    else:
        print("\nMain watchlist complete.")


def search_titles(titles: list[Title], watched: dict[str, str], query: str) -> None:
    normalized = query.casefold().strip()
    if not normalized:
        raise SystemExit("Search query cannot be empty.")

    matches = [title for title in titles if normalized in title.title.casefold()]
    
    if not matches:
        print(f"❌ Missing: '{query}' not found in watchlist")
        return

    print(f"✅ Found {len(matches)} result(s) for '{query}':\n")
    
    width = max(len(title.key) for title in matches)
    for title in matches:
        marker = "x" if title.key in watched else " "
        bonus = " (bonus)" if title.bonus else ""
        suffix = f" — watched {watched[title.key]}" if title.key in watched else ""
        print(
            f"[{marker}] {title.key.rjust(width)}. {title.title} "
            f"({title.kind}, {title.runtime}{bonus}){suffix}"
        )


def mark_watched(titles: list[Title], watched: dict[str, str], entry: str) -> None:
    matched_titles = [find_title(titles, query) for query in parse_entries(entry)]
    if not matched_titles:
        raise SystemExit("No watchlist entries provided.")

    watched_on = date.today().isoformat()
    for title in matched_titles:
        watched[title.key] = watched_on

    save_progress(watched)
    for title in matched_titles:
        print(f"Marked watched: {title.key}. {title.title}")


def mark_unwatched(titles: list[Title], watched: dict[str, str], entry: str) -> None:
    matched_titles = [find_title(titles, query) for query in parse_entries(entry)]
    if not matched_titles:
        raise SystemExit("No watchlist entries provided.")

    changed = False
    for title in matched_titles:
        if title.key not in watched:
            print(f"Already unwatched: {title.key}. {title.title}")
            continue

        del watched[title.key]
        changed = True
        print(f"Marked unwatched: {title.key}. {title.title}")

    if changed:
        save_progress(watched)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="MCU_tracker",
        description="Track watched entries from reader/data/watchlist.en.json.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    list_parser = subparsers.add_parser("list", help="Show watchlist progress.")
    list_parser.add_argument(
        "--bonus",
        action="store_true",
        help="Include the optional Fox X-Men bonus titles.",
    )
    list_parser.add_argument(
        "--order",
        choices=["release", "chronological"],
        default="release",
        help="Sort order: 'release' (default) or 'chronological'.",
    )

    subparsers.add_parser("status", help="Show totals and the next entries.")

    search_parser = subparsers.add_parser(
        "search", help="Find entries and show their timeline position."
    )
    search_parser.add_argument("query", help="Title text to search for.")

    watched_parser = subparsers.add_parser("watched", help="Mark an entry as watched.")
    watched_parser.add_argument(
        "entry", help="Entry number, bonus key, title text, or comma-separated entries."
    )

    unwatched_parser = subparsers.add_parser(
        "unwatched", help="Mark an entry as not watched."
    )
    unwatched_parser.add_argument(
        "entry", help="Entry number, bonus key, title text, or comma-separated entries."
    )

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    titles = parse_watchlist()
    watched = load_progress()

    if args.command == "list":
        print_list(titles, watched, include_bonus=args.bonus, order=args.order)
    elif args.command == "status":
        print_status(titles, watched)
    elif args.command == "search":
        search_titles(titles, watched, args.query)
    elif args.command == "watched":
        mark_watched(titles, watched, args.entry)
    elif args.command == "unwatched":
        mark_unwatched(titles, watched, args.entry)
    else:
        parser.error(f"Unsupported command: {args.command}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
